# EU-region PostgreSQL (t.ex. AWS eu-north-1, Azure Sweden Central)
DATABASE_URL="postgresql://user:password@localhost:5432/gdpr_myndighet?schema=public"

# NextAuth — generera med: openssl rand -base64 32
AUTH_SECRET=""

# Offentlig URL (lokal utveckling)
AUTH_URL="http://localhost:3000"

# Bekräftelsemejl vid registrering (Resend — https://resend.com). Lokalt loggas länken i terminalen om nycklar saknas.
RESEND_API_KEY=""
# Avsändare, t.ex. "GDPR-verktyg <onboarding@din-domän.se>" (domän måste vara verifierad i Resend)
EMAIL_FROM=""

# Stripe (självbetjäning — hybrid med faktura i admin)
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# Pris-ID:n från Stripe Dashboard (engång resp. årsabonnemang)
STRIPE_PRICE_ONE_TIME=""
STRIPE_PRICE_ANNUAL=""

# OpenAI — automatisk dokumentanalys (server-side only)
# Skapa nyckel: https://platform.openai.com/api-keys
OPENAI_API_KEY=""
# Valfritt: modellnamn (standard gpt-4o-mini i kodbasen om tom)
OPENAI_MODEL=""
